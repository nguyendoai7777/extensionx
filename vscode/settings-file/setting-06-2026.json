{
	"editor.lineHeight": 0,
	"editor.minimap.maxColumn": 10,
	"editor.tabSize": 2,
	"editor.fontSize": 10,
	"editor.fontLigatures": true,
	"editor.detectIndentation": false,
	"editor.fontFamily": "FiraCode Nerd Font",
	"editor.inlayHints.padding": true,
	"editor.suggestSelection": "first",
	"editor.snippetSuggestions": "inline",
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.inlayHints.fontSize": 8,
	"workbench.colorTheme": "Dracula Theme",
	"workbench.sideBar.location": "left",
	"workbench.editor.revealIfOpen": true,
	"workbench.editor.enablePreviewFromQuickOpen": false,
	"workbench.preferredDarkColorTheme": "Dracula Theme",
	"workbench.iconTheme": "material-icon-theme",
	"css.validate": false,
	"window.zoomLevel": 0,
	"liveServer.settings.donotShowInfoMsg": true,
	"emmet.triggerExpansionOnTab": true,
	"explorer.confirmDelete": false,
	"git.autofetch": true,
	"gitlens.rebaseEditor.ordering": "asc",
	"scss.completion.triggerPropertyValueCompletion": false,
	"javascript.updateImportsOnFileMove.enabled": "always",
	"javascript.inlayHints.variableTypes.enabled": true,
	"javascript.inlayHints.parameterTypes.enabled": true,
	"javascript.inlayHints.functionLikeReturnTypes.enabled": true,
	"javascript.inlayHints.parameterNames.enabled": "all",
	"javascript.inlayHints.propertyDeclarationTypes.enabled": true,
	"typescript.enablePromptUseWorkspaceTsdk": true,
	"typescript.disableAutomaticTypeAcquisition": true,
	"typescript.inlayHints.parameterNames.enabled": "all",
	"typescript.implementationsCodeLens.enabled": true,
	"typescript.inlayHints.enumMemberValues.enabled": true,
	"typescript.inlayHints.parameterTypes.enabled": true,
	"typescript.inlayHints.variableTypes.enabled": true,
	"typescript.inlayHints.propertyDeclarationTypes.enabled": true,
	"typescript.format.insertSpaceAfterOpeningAndBeforeClosingJsxExpressionBraces": true,
	"typescript.inlayHints.functionLikeReturnTypes.enabled": true,
	"typescript.locale": "en",
	"typescript.suggest.completeFunctionCalls": true,
	"typescript.format.insertSpaceAfterFunctionKeywordForAnonymousFunctions": false,
	"security.workspace.trust.enabled": false,
	"security.workspace.trust.startupPrompt": "never",
	"extensions.ignoreRecommendations": true,
	"terminal.integrated.fontSize": 12,
	"terminal.external.windowsExec": "\"C:\\Program Files\\PowerShell\\7\\pwsh.exe\" -WorkingDirectory ~",
	"terminal.integrated.automationProfile.linux": null,
	"terminal.integrated.defaultProfile.osx": "/bin/zsh",
	"terminal.integrated.defaultProfile.linux": "zsh",
	"terminal.integrated.env.windows": { "PATH": "${workspaceFolder}\\node_modules\\.bin;${env:PATH}" }, // hướng dẫn terminal dùng biến cục bộ ngay trong project
	"terminal.integrated.env.osx": { "PATH": "${workspaceFolder}/node_modules/.bin:${env:PATH}" }, // hướng dẫn terminal dùng biến cục bộ ngay trong project
	"terminal.integrated.env.linux": { "PATH": "${workspaceFolder}/node_modules/.bin:${env:PATH}" }, // hướng dẫn terminal dùng biến cục bộ ngay trong project
	"html.format.extraLiners": "",
	"html.format.wrapLineLength": 0,
	"html.format.indentInnerHtml": true,
	"prettier.vueIndentScriptAndStyle": true,
	"prettier.singleQuote": true,
	"prettier.printWidth": 180,
	"prettier.jsxSingleQuote": true,
	"prettier.useTabs": true,
	"files.associations": {
		"*.jsx": "javascriptreact",
		"*.tsx": "typescriptreact",
	},
	"files.exclude": {
		"**/.git": false,
		"**/.svn": true,
		"**/.hg": true,
		"**/CVS": true,
		"**/.DS_Store": false,
		"**/Thumbs.db": true,
	},
	"[javascript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.autoClosingBrackets": "always",
	},
	"[scss]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"[typescript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"[html]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"[xml]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"[json]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.quickSuggestions": {
			"strings": true,
		},
		"editor.suggest.insertMode": "replace",
	},
	"editor.semanticHighlighting.enabled": "configuredByTheme",
	"editor.tokenColorCustomizations": {
		"[Dracula]": {
			"textMateRules": [
				{
					"name": "",
					"scope": ["storage.type.annotation.dart"],
					"settings": {
						"foreground": "#BD93F9",
						"fontStyle": "italic",
					},
				},
				{
					"name": "",
					"scope": [
						/* "entity.name.function.ts", */
						"meta.decorator.ts",
						"punctuation.definition.typeparameters.begin.ts",
						"punctuation.definition.typeparameters.end.ts",
						"entity.name.type.class",
						"punctuation.definition.typeparameters.begin.tsx",
						"punctuation.definition.typeparameters.end.tsx",
					],
					"settings": {
						"foreground": "#8BE9FD",
						"fontStyle": "italic",
					},
				},
				{
					"name": "",
					"scope": [
						"variable.other.property.tsx",
						"variable.other.property.ts",
						"variable.other.property.jsx",
						"variable.other.property.js",
						"variable.other.constant.object.property.ts",
						"variable.other.constant.object.property.tsx",
						"variable.other.constant.object.property.jsx",
						"variable.other.constant.object.property.js",
						"variable.other.constant.property.ts",
						"variable.other.constant.property.tsx",
						"variable.other.constant.property.js",
						"variable.other.constant.property.jsx",
						"variable.other.readwrite.ts",
						"variable.other.readwrite.tsx",
						"variable.other.readwrite.js",
						"variable.other.readwrite.jsx",
						"variable.object.property.ts",
						"variable.other.object.property.ts",
						"variable.other.object.property.tsx",
					],
					"settings": {
						"foreground": "#FFB86C",
						"fontStyle": "",
					},
				},
				{
					"name": "",
					"scope": [
						"variable.language.this.ts",
						"variable.language.this.tsx",
						"variable.language.this.js",
						"variable.language.this.jsx",
						"constant.language.boolean.true.ts",
						"constant.language.boolean.false.ts",
						"constant.language.boolean.true.tsx",
						"constant.language.boolean.false.tsx",
						"constant.language.boolean.true.js",
						"constant.language.boolean.false.js",
						"constant.language.boolean.true.jsx",
						"constant.language.boolean.false.jsx",
						"constant.language.undefined.ts",
						"constant.language.undefined.tsx",
						"constant.language.undefined.js",
						"constant.language.undefined.jsx",
						"constant.language.null.ts",
						"constant.language.null.tsx",
						"constant.language.null.js",
						"constant.language.null.jsx",
					],
					"settings": {
						"foreground": "#FF79C6",
						"fontStyle": "",
					},
				},
				{
					"name": "",
					"scope": ["support.variable.tsx", "support.variable.ts", "support.variable.jsx", "support.variable.js"],
					"settings": {
						"foreground": "#8BE9FD",
						"fontStyle": "",
					},
				},
				{
					"name": "",
					"scope": ["variable.parameter"],
					"settings": {
						"foreground": "#cccccc",
						"fontStyle": "italic",
					},
				},
				{
					"name": "",
					"scope": ["support.type.primitive.ts", "support.type.primitive.tsx", "keyword.operator.new.ts", "variable.language.super.ts", "variable.language.super.tsx"],
					"settings": {
						"foreground": "#FF79C6",
						"fontStyle": "",
					},
				},
				{
					"name": "",
					"scope": ["entity.name.type.parameter"],
					"settings": {
						"foreground": "#BD93F9",
						"fontStyle": "italic",
					},
				},
				{
					"name": "",
					"scope": [
						"keyword.operator.logical.ts",
						"keyword.operator.assignment.ts",
						"keyword.operator.relational.ts",
						"keyword.operator.logical.tsx",
						"keyword.operator.assignment.tsx",
						"keyword.operator.relational.tsx",
						"keyword.operator.logical.js",
						"keyword.operator.assignment.js",
						"keyword.operator.relational.js",
						"keyword.operator.logical.jsx",
						"keyword.operator.assignment.jsx",
						"keyword.operator.relational.jsx",
						"keyword.operator.type.annotation.ts",
						"keyword.operator.type.annotation.tsx",
					],
					"settings": {
						"foreground": "#fff",
						"fontStyle": "",
					},
				},
				{
					"name": "",
					"scope": ["variable.other.property.tsx", "variable.other.readwrite.jsx", "variable.object.property.ts"],
					"settings": {
						"foreground": "#FFB86C",
						"fontStyle": "",
					},
				},
				/* Angular template */ {
					"name": "",
					"scope": ["keyword.control.block.kind.ng", "keyword.control.block.transition.ng"],
					"settings": {
						"foreground": "#93ebff",
						"fontStyle": "italic bold",
					},
				},
				{
					"name": "",
					"scope": ["punctuation.definition.string.begin.html", "punctuation.definition.string.end.html", "keyword.operator.comparison.ts"],
					"settings": {
						"foreground": "#fff",
					},
				},
				{
					"name": "",
					"scope": ["entity.other.ng-binding-name.ngTemplateOutlet.html", "entity.other.ng-binding-name.template.html"],
					"settings": {
						"foreground": "#BD93F9",
						"fontStyle": "italic bold",
					},
				},
				{
					"name": "",
					"scope": ["meta.tag.custom.start.html", "meta.tag.custom.end.html"],
					"settings": {
						"foreground": "#93ebff",
						"fontStyle": "italic",
					},
				} /* end Angular tempate */ /* dart - flutter */,
			],
		},
	},
	"css.hover.documentation": false,
	"css.hover.references": false,
	"less.hover.documentation": false,
	"less.hover.references": false,
	"html.hover.references": false,
	"html.hover.documentation": false,
	"scss.hover.documentation": false,
	"scss.hover.references": false,
	"[powershell]": {
		"editor.defaultFormatter": "ms-vscode.powershell",
	},
	"workbench.startupEditor": "none",
	"workbench.colorCustomizations": {
		"editorInlayHint.foreground": "#9c9c9c",
		"inline.css.propertyName": "#6ee2fc",
		"inline.css.punctuation": "#fff",
		"inline.css.supportFunction": "#4aeb00",
		"inline.css.valueConstant": "#BD93F9",
		"inline.css.valueNumeric": "#BD93F9",
		"inline.css.valueNumericUnit": "#FF79C6",
		"inline.css.keywordImportant": "#FF79C6",
		"inline.css.string": "#63ECF1",
	},
	"diffEditor.ignoreTrimWhitespace": false,
	"workbench.editor.editorActionsLocation": "titleBar",
	"chat.viewSessions.orientation": "stacked",
}
